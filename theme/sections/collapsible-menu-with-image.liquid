{% assign background_section_rgb = section.settings['section-color-overlay'] | color_to_rgb %}
{% assign heading_rgb = section.settings['color-heading'] | color_to_rgb %}
{% assign text_rgb = section.settings['color-body-text'] | color_to_rgb %}

{{ 'collapsible-menu-with-image.css' | asset_url | stylesheet_tag }}
{{ 'section-video.css' | asset_url | stylesheet_tag }}

<style>
  [id="shopify-section-{{ section.id }}"] {
    {% if background_section_rgb != 'rgba(0, 0, 0, 0.0)' %}
      --color-overlay-rgb: {{ section.settings.section-color-overlay | color_to_rgb | remove: 'rgb(' | remove: ')' }};
      --color-overlay-opacity: {{ section.settings.section-color-overlay-opacity | divided_by: 100.0 }};
    {% endif %}

    {% if heading_rgb != 'rgba(0, 0, 0, 0.0)' %}
      --color-heading: {{ section.settings.color-heading }};
    {% endif %}

    {% if text_rgb != 'rgba(0, 0, 0, 0.0)' %}
      --color-custom-text: {{ section.settings.color-body-text }};
    {% endif %}
  }

  [data-section-id="{{ section.id }}"] {
    --color-collapsible-background: {{ section.settings.color-collapsible-background }};

    --collapsible-heading-font: var(--font-base);
    --collapsible-heading-font-style: var(--font-base-style);
    --collapsible-heading-font-weight: var(--font-base-weight);

    {% if section.settings.heading_font_style == 'heading' %}
      --collapsible-heading-font: var(--font-headline);
      --collapsible-heading-font-style: var(--font-headline-style);
      --collapsible-heading-font-weight: var(--font-headline-weight);
    {% endif %}

    {% if section.settings.margin-top %}
      --section-gap-top: {{ section.settings.margin-top }}px;
    {% endif %}

    {% if section.settings.margin-bottom %}
      --section-gap-bottom: {{ section.settings.margin-bottom }}px;
    {% endif %}

    --desktop-percentage-image-width: {{ section.settings.desktop-percentage-image-width }}%;
    --menu-alignment: {% if section.settings.menu_alignment == 'top' %}flex-start{% else %}center{% endif %};

    {% if section.settings.slide_height == 'fixed_height' %}
      --section-height: {{ section.settings.mobile_fixed_height }}px;
      --section-height-desk: {{ section.settings.desktop_fixed_height }}px;
    {% endif %}
  }

  [id="shopify-section-{{ section.id }}"] .headline--rich {
    {% if heading_rgb != 'rgba(0, 0, 0, 0.0)' %}
      --color-custom-text: {{ section.settings.color-heading }};
    {% endif %}
  }

  {% if section.settings.full-width-enabled %}
    [data-section-id="{{ section.id }}"] .collapsible-menu-with-image__image {
      --border-radius: 0;
    }
  {% endif %}

  {% for block in section.blocks %}
    {% if block.settings.icon_advanced_settings %}
      [data-block-id="{{ block.id }}"] {
        --icon-height: {{ block.settings.icon_height }}px;
        --icon-height-desktop: {{ block.settings.icon_height_desktop }}px;
        --icon-margin: {{ block.settings.icon_margin }}px;
        --icon-margin-desktop: {{ block.settings.icon_margin_desktop }}px;
      }
    {% endif %}
  {% endfor %}
</style>

{% if section.settings['full-width-enabled'] %}
  {% assign customwrapperclass = 'hero__wrapper--full' %}
{% else %}
  {% assign customwrapperclass = 'hero__wrapper' %}
{% endif %}

<div data-section-id="{{ section.id }}" class="{{ customwrapperclass }}">
  {% if section.settings.heading_richtext != blank %}
    <div class="headline headline--rich {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
      {{ section.settings.heading_richtext }}
    </div>
  {% endif %}
  <div class="collapsible-menu-with-image {% if section.settings.layout == 'text_first' %}collapsible-menu-with-image--rev{% endif %}" data-height="{{ section.settings.slide_height }}">
    <div class="collapsible-menu-with-image__image {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
      {% render 'hero',
        desktop_image: section.settings.desktop_image,
        mobile_image: section.settings.mobile_image,
        video: section.settings.video_hosted,
        mobile_video: section.settings.video_hosted_mobile,
        placeholder: 'detailed-apparel-1'
      %}
    </div>
    <div class="collapsible-menu-with-image__menu">
      {%- for block in section.blocks -%}
        {%- if block.settings.heading != blank or block.settings.content != blank or request.design_mode -%}
          <collapsible-section
            {{ block.shopify_attributes }}
            data-block-id="{{ block.id }}"
            {% if settings.animations %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
            class="wt-collapse wt-collapse--always {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
          >
            <div
              class="wt-collapse__trigger wt-collapsible__trigger {% if block.settings.open_by_default %} wt-collapse__trigger--active {% endif %}"
              role="button"
              tabindex="0"
              data-open="{{ block.settings.open_by_default }}"
              aria-expanded="{{ block.settings.open_by_default }}"
              aria-controls="CollapsibleTab-{{ block.id }}"
            >
              <div class="wt-collapse__trigger__text{% if block.settings.icon_image != blank %} wt-collapse__trigger__text--has-icon-image{% endif %}">
                {% if block.settings.icon_image != blank %}
                  <div class="wt-collapse__trigger__icon">
                    {% render 'responsive-icon-image',
                      image: block.settings.icon_image,
                      height_desktop: block.settings.icon_height_desktop,
                      height_mobile: block.settings.icon_height,
                      class: 'hero__icon'
                    %}
                  </div>
                {% elsif block.settings.icon != 'none' %}
                  <div class="wt-collapse__trigger__icon">
                    {% render 'icon-accordion', icon: block.settings.icon, class: 'hero__icon' %}
                  </div>
                {% endif %}
                <span class="wt-collapse__trigger__title">
                  {{- block.settings.heading -}}
                </span>
              </div>
              <div class="wt-icon" aria-hidden="true">
                {% render 'icons', id: 'plus' %}
              </div>
            </div>
            <div class="wt-collapse__target wt-collapsible__target" id="CollapsibleTab-{{ block.id }}">
              <div class="wt-collapse__target--text rte">
                {{ block.settings.content }}
              </div>
            </div>
          </collapsible-section>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

