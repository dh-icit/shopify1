{% liquid
  assign tab_buttons_spacing = '16'
  if section.settings.progress_button_select == 'none'
    assign tab_buttons_spacing = '32'
  endif
%}

{% assign background_rgb = section.settings.background_color | color_to_rgb %}
{% assign text_rgb = section.settings['color-body-text'] | color_to_rgb %}
{% assign progres_bar = section.settings['active_progress_bar_color'] | color_to_rgb %}
{% assign active_button_color = section.settings['active_button_text_color'] | color_to_rgb %}
{% assign active_button_background = section.settings['active_button_background_color'] | color_to_rgb %}


{{ 'swiper.css' | asset_url | stylesheet_tag }}
{{ 'section-collection-navigator.css' | asset_url | stylesheet_tag }}

<script src="{{ 'collection-navigator.js' | asset_url }}" type="module"></script>

<style>
  #shopify-section-{{ section.id }} {
    --grid-columns-desktop: {{ section.settings.columns_desktop }};
    --grid-gap-desktop: {{ section.settings.spacing_desktop }}px;
    --grid-columns-mobile: {{ section.settings.columns_mobile }};
    --grid-gap-mobile: {{ section.settings.spacing_mobile }}px;
    --products-to-show-mobile: {{ section.settings.products_to_show_mobile }};
    --products-to-show-desktop: {{ section.settings.products_to_show_desktop }};    

    {% if text_rgb != 'rgba(0, 0, 0, 0.0)' %}
      --color-custom-text: {{ section.settings.color-body-text }};
      --color-price: {{ section.settings.color-body-text }};
      --color-brand: {{ section.settings.color-body-text }};
      --color-star-rating: {{ section.settings.color-body-text }};
      {% if section.settings.progress_button_select == 'none' %}
        --color-active-button-text: {{ section.settings.color-body-text }};
      {% endif %}
    {% endif %}

    {% if background_rgb != 'rgba(0, 0, 0, 0.0)' %}
      --color-overlay-rgb: {{ section.settings.background_color | color_to_rgb | remove: 'rgb(' | remove: 'rgba(' | remove: ')' }};
      --color-overlay-opacity: 1;
    {% endif %}

    {% if progres_bar != 'rgba(0, 0, 0, 0.0)' %}
      --color-progress-active: {{ section.settings.active_progress_bar_color }};
    {% endif %}
    
    {% if active_button_color != 'rgba(0, 0, 0, 0.0)' %}
      --color-active-button-text: {{ section.settings.active_button_text_color }};
    {% endif %}

    {% if active_button_background != 'rgba(0, 0, 0, 0.0)' %}
      --color-active-button-background: {{ section.settings.active_button_background_color }};
    {% endif %}

    {% if section.settings.margin-top %}
      --section-gap-top: {{ section.settings.margin-top }}px;
    {% endif %}
    {% if section.settings.margin-bottom %}
      --section-gap-bottom: {{ section.settings.margin-bottom }}px;
    {% endif %}
  }
</style>
{% if section.settings.enable_quick_add_button %}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'subscription-widget.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'variant-dropdown.js' | asset_url }}" defer="defer"></script>
{% endif %}

{% if section.settings.enable_full_width %}
  {% assign width_line = 'hero__wrapper--full' %}
{% else %}
  {% assign width_line = 'hero__wrapper' %}
{% endif %}

<div
  data-section-id="{{ section.id }}"
  class="wt-collection-navigator {{ width_line }}"
>
  {% if section.settings.heading_richtext != blank %}
    <div class="headline headline--rich {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
      {{ section.settings.heading_richtext | strip }}
    </div>
  {% endif %}

  <collection-navigator
    data-tab-buttons-spacing="{{ tab_buttons_spacing }}"
  >
    <div class="wt-collection-navigator__tabs">
      <div
        class="
          swiper wt-collection-navigator__swiper-tabs
          {% if section.settings.enable_progress_bar %}
              wt-collection-navigator__swiper-tabs--progress
          {% endif %}
        "
      >
        <div class="swiper-wrapper wt-collection-navigator__tabs-wrapper" role="tablist">
          {% for block in section.blocks %}
            <div class="swiper-slide wt-collection-navigator__tab-item" role="presentation" {{ block.shopify_attributes }}>
              <button
                type="button"
                role="tab"
                tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                aria-label="{{ block.settings.tab_label | default: block.settings.collection.title }}"
                class="
                  wt-button wt-collection-navigator__tab-button
                  {% if section.settings.progress_button_select == 'primary' %}
                    hero__button--primary
                  {% elsif section.settings.progress_button_select == 'secondary' %}
                    hero__button--secondary
                  {% elsif section.settings.progress_button_select == 'link' %}
                    hero__button--link
                  {% elsif section.settings.progress_button_select == 'none' %}
                    wt-collection-navigator__tab-button--none
                  {% endif %}
                "
              >
                <span>{{ block.settings.tab_label | default: block.settings.collection.title }}</span>
              </button>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="wt-collection-navigator__panels">
      <div class="swiper wt-collection-navigator__swiper-panels">
        <div class="swiper-wrapper wt-collection-navigator__panels-wrapper">
          {% for block in section.blocks %}
            {% liquid
              assign products = block.settings.collection.products
              if block.settings.product_list != empty
                assign products = block.settings.product_list
              endif
            %}
            <div class="swiper-slide wt-collection-navigator__panel-item" data-block-id="{{ block.id }}" data-has-products="{% if products != empty %}true{% else %}false{% endif %}" aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}">
              <div class="wt-collection-navigator__panel-item-content">
                <div class="wt-collection-navigator__grid">
                  {% for card_product in products limit: section.settings.products_to_show_desktop %}
                    {% if section.settings.show_secondary_image and card_product.images[1] %}
                      {% assign image_hover = card_product.images[1] %}
                    {% else %}
                      {% assign image_hover = false %}
                    {% endif %}
                    {% assign color_swatch_class = '' %}

                    {% comment %} Hide on mobile when beyond products_to_show_mobile; show from tablet. Products between mobile and desktop limits get both classes so they are visible only from tablet up. {% endcomment %}
                    {% if forloop.index > section.settings.products_to_show_mobile %}
                      {% assign color_swatch_class = 'wt-to-tablet-hidden wt-from-tablet-visible' %}
                    {% endif %}

                    {% render 'card',
                      color_swatch_class: color_swatch_class,
                      card_product: card_product,
                      img: card_product.featured_media,
                      img_hover: image_hover,
                      title: card_product.title,
                      subtitle: card_product.vendor,
                      rating: section.settings.show_product_rating,
                      reviews: card_product.metafields.reviews,
                      options: false,
                      url: card_product.url,
                      uri: card_product.handle,
                      text_alignment: section.settings.text_alignment,
                      variants: card_product.variants,
                      product_options: card_product.options,
                      product: card_product,
                      media_aspect_ratio: section.settings.image_ratio,
                      enable_quick_add_button: section.settings.enable_quick_add_button,
                      quick_add_mode: section.settings.quick_add_mode,
                      enable_vendor_link: section.settings.enable_vendor_link,
                      show_video: section.settings.show_video
                    %}
                  {% endfor %}

                  {% if request.design_mode and products == blank %}
                    {% for i in (1..section.settings.products_to_show_desktop) %}
                      {% assign placeholder_image_index = i | modulo: 4 %}
                      {% if placeholder_image_index == 0 %}
                        {% assign placeholder_image_index = 1 %}
                      {% endif %}
                      {% render 'card',
                        placeholder_image_index: placeholder_image_index,
                        title: 'Example product title',
                        subtitle: 'Vendor',
                        price: '1999',
                        rating: section.settings.show_product_rating,
                        options: false,
                        text_alignment: section.settings.text_alignment,
                        enable_quick_add_button: section.settings.enable_quick_add_button,
                        quick_add_mode: section.settings.quick_add_mode
                      %}
                    {% endfor %}
                  {% endif %}
                </div>

                {% if section.settings.show_view_all %}
                  <a
                    aria-label="{{ 'aria-label.featured-collection' | t }}"
                    class="
                      hero__button
                      hero__button--primary {% if section.settings.button_select != 'primary' %} hero__button--secondary {% endif %}{% if section.settings.button_select == 'link' %} hero__button--link {% endif %}
                      wt-collection-navigator__view-all-btn
                      {% if section.settings.products_to_show_mobile < block.settings.collection.all_products_count %}
                       wt-collection-navigator__view-all-btn--mobile
                      {% endif %}
                      {% if section.settings.products_to_show_desktop < block.settings.collection.all_products_count %}
                       wt-collection-navigator__view-all-btn--desktop
                      {% endif %}
                    "
                    href="{{ block.settings.collection.url }}"
                  >
                    <span class="wt-collection-navigator__btn-text">{{ 'aria-label.featured-collection' | t }}</span>
                  </a>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </collection-navigator>
</div>

{% schema %}
{
  "name": "t:sections.collection-navigator.name",
  "tag": "section",
  "class": "collection-navigator-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.collection-navigator.settings.header__1.content",
      "info": "t:sections.collection-navigator.settings.header__1.info"
    },
    {
      "type": "richtext",
      "id": "heading_richtext",
      "label": "t:sections.logo-banner.settings.content.headline.label",
      "default": "<h2>Collection navigator</h2>"
    },
    {
      "type": "checkbox",
      "id": "enable_full_width",
      "default": true,
      "label": "t:sections.settings.settings.section-full-width.label"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "t:sections.featured-collection.settings.show_view_all.label"
    },
    {
      "type": "select",
      "id": "button_select",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.settings.settings.button_select.primary.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.settings.settings.button_select.secondary.label"
        },
        {
          "value": "link",
          "label": "t:sections.settings.settings.button_select.link.label"
        }
      ],
      "default": "primary",
      "label": "t:sections.featured-collection.settings.button_select.label"
    },
    {
      "type": "header",
      "content": "t:sections.collection-navigator.settings.header__2.content"
    },
    {
      "type": "checkbox",
      "id": "enable_progress_bar",
      "label": "t:sections.collection-navigator.settings.enable_progress_bar.label",
      "default": true
    },
    {
      "type": "select",
      "id": "progress_button_select",
      "options": [
        {
          "value": "none",
          "label": "t:sections.collection-navigator.settings.progress_button_select.options.none.label"
        },
        {
          "value": "primary",
          "label": "t:sections.settings.settings.button_select.primary.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.settings.settings.button_select.secondary.label"
        }
      ],
      "default": "none",
      "label": "t:sections.collection-navigator.settings.progress_button_select.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.desktop_version"
    },
    {
      "type": "range",
      "id": "products_to_show_desktop",
      "min": 3,
      "max": 24,
      "step": 1,
      "default": 4,
      "label": "t:sections.featured-collection.settings.products_to_show.label"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "options": [
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        },
        {
          "value": "5",
          "label": "5"
        }
      ],
      "default": "4",
      "label": "t:sections.collection-navigator.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "spacing_desktop",
      "options": [
        {
          "value": "8",
          "label": "8px"
        },
        {
          "value": "16",
          "label": "16px"
        },
        {
          "value": "24",
          "label": "24px"
        }
      ],
      "default": "16",
      "label": "t:sections.collection-navigator.settings.spacing_desktop.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.mobile_version"
    },
    {
      "type": "range",
      "id": "products_to_show_mobile",
      "min": 3,
      "max": 24,
      "step": 1,
      "default": 4,
      "label": "t:sections.featured-collection.settings.products_to_show.label"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2",
      "label": "t:sections.collection-navigator.settings.columns_mobile.label"
    },
    {
      "type": "select",
      "id": "spacing_mobile",
      "options": [
        {
          "value": "4",
          "label": "4px"
        },
        {
          "value": "8",
          "label": "8px"
        },
        {
          "value": "12",
          "label": "12px"
        },
        {
          "value": "16",
          "label": "16px"
        }
      ],
      "default": "16",
      "label": "t:sections.collection-navigator.settings.spacing_mobile.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__3.content"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        {
          "value": "center",
          "label": "t:sections.featured-collection.settings.text_alignment.center.label"
        },
        {
          "value": "left",
          "label": "t:sections.featured-collection.settings.text_alignment.left.label"
        }
      ],
      "default": "left",
      "label": "t:sections.featured-collection.settings.text_alignment.label"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.featured-collection.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.featured-collection.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.featured-collection.settings.image_ratio.options__3.label"
        }
      ],
      "default": "square",
      "label": "t:sections.featured-collection.settings.image_ratio.label"
    },
    {
      "type": "checkbox",
      "id": "show_video",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.show_video.label",
      "info": "t:sections.main-collection-product-grid.settings.show_video.info"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "t:sections.featured-collection.settings.show_secondary_image.label"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "t:sections.featured-collection.settings.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "enable_vendor_link",
      "label": "t:sections.global.enable_vendor_link",
      "visible_if": "{{ section.settings.show_vendor }}"
    },
    {
      "type": "checkbox",
      "id": "show_product_rating",
      "default": true,
      "label": "t:sections.featured-collection.settings.show_product_rating.label",
      "info": "t:sections.featured-collection.settings.show_product_rating.info"
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add_button",
      "default": false,
      "label": "t:sections.featured-collection.settings.enable_quick_add_button.label",
      "info": "t:sections.featured-collection.settings.enable_quick_add_button.info"
    },
    {
      "type": "select",
      "id": "quick_add_mode",
      "label": "t:sections.featured-collection.settings.quick_add_layout.label",
      "options": [
        {
          "value": "hover_desktop",
          "label": "t:sections.featured-collection.settings.quick_add_layout.options.hover.label"
        },
        {
          "value": "below_product",
          "label": "t:sections.featured-collection.settings.quick_add_layout.options.below.label"
        }
      ],
      "default": "hover_desktop",
      "visible_if": "{{ section.settings.enable_quick_add_button }}"
    },
    {
      "type": "header",
      "content": "t:sections.global.colors",
      "info": "t:sections.global.colors-info"
    },
    {
      "type": "color",
      "id": "active_progress_bar_color",
      "default": "transparent",
      "label": "t:sections.collection-navigator.settings.active_progress_bar_color.label",
      "visible_if": "{{ section.settings.enable_progress_bar }}"
    },
    {
      "type": "color",
      "id": "active_button_text_color",
      "default": "transparent",
      "label": "t:sections.collection-navigator.settings.active_button_text_color.label"
    },
    {
      "type": "color",
      "id": "active_button_background_color",
      "default": "transparent",
      "label": "t:sections.collection-navigator.settings.active_button_background_color.label",
      "visible_if": "{{ section.settings.progress_button_select != 'none' }}"
    },
    {
      "type": "color",
      "id": "color-body-text",
      "default": "transparent",
      "label": "t:sections.settings.settings.text-color.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "default": "transparent",
      "label": "t:sections.settings.settings.background-color.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.section_spacing"
    },
    {
      "type": "range",
      "id": "margin-top",
      "min": 0,
      "max": 100,
      "unit": "px",
      "step": 4,
      "default": 20,
      "label": "t:sections.rich-text.settings.top_distance.label"
    },
    {
      "type": "range",
      "id": "margin-bottom",
      "min": 0,
      "max": 100,
      "unit": "px",
      "step": 4,
      "default": 20,
      "label": "t:sections.rich-text.settings.bottom_distance.label",
      "info": "t:sections.separator.settings.separator-bottom.info"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "t:sections.collection-navigator.blocks.collection.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "tab_label",
          "label": "t:sections.collection-navigator.blocks.collection.settings.tab_label.label"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.featured-collection.settings.collection.label"
        },
        {
          "type": "product_list",
          "id": "product_list",
          "label": "t:sections.featured-collection.settings.products.label",
          "info": "t:sections.featured-collection.settings.products.info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection-navigator.presets.name",
      "category": "t:sections.categories.collections",
      "blocks": [
        {
          "type": "collection",
          "settings": {
            "tab_label": "t:sections.collection-navigator.presets.tab_1"
          }
        },
        {
          "type": "collection",
          "settings": {
            "tab_label": "t:sections.collection-navigator.presets.tab_2"
          }
        },
        {
          "type": "collection",
          "settings": {
            "tab_label": "t:sections.collection-navigator.presets.tab_3"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
