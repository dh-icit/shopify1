                },
                {
                "value": "24",
                "label": "t:sections.main-collection-product-grid.settings.spacing_desktop.3.label"
                }
            ],
            "default": "16",
            "label": "t:sections.grid-view-with-drawer.settings.large_screen.spacing.label"
        },
        {
            "type": "header",
            "content": "t:sections.global.mobile_version",
        },
        {
            "type": "range",
            "label": "t:sections.grid-view-with-drawer.settings.mobile_screen.columns_per_row.label",
