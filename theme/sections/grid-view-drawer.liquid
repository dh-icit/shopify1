            "id": "columns_per_row_mobile",
            "min": 1.0,
            "max": 1.5,
            "step": 0.1,
            "default": 1.1,
        },
        {
            "type": "select",
            "id": "spacing_mobile",
            "options": [
                {
                    "value": "4",
                    "label": "4px"
                },
                {
                    "value": "8",
                    "label": "8px"
                },
                {
                    "value": "12",
                    "label": "12px"
                },
                {
                    "value": "16",
                    "label": "16px"
                }
            ],
            "default": "16",
            "label": "t:sections.grid-view-with-drawer.settings.mobile_screen.spacing.label"
        },
        {
            "type": "header",
            "content": "t:sections.global.colors",
            "info": "t:sections.global.colors-info"
        },
        {
