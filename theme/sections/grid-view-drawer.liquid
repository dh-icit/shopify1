{{ 'section-video.css' | asset_url | stylesheet_tag }}
<script src="{{ 'drawer-content.js' | asset_url }}" defer="defer"></script>

{% assign background_rgb = section.settings.background_color | color_to_rgb %}
{% assign text_rgb = section.settings['color-body-text'] | color_to_rgb %}

<style>
    [data-section-id="{{ section.id }}"] {
        {% if section.settings.margin-top %}
          --section-gap-top: {{ section.settings.margin-top }}px;
        {% endif %}

        {% if section.settings.margin-bottom %}
            --section-gap-bottom: {{ section.settings.margin-bottom }}px;
        {% endif %}

        {% if section.settings.full-width-enabled %}
            --border-radius: 0;
        {% endif %}

        {% if background_rgb != 'rgba(0, 0, 0, 0.0)' %}
            --color-background: {{ section.settings.background_color }};
        {% endif %}

        {% if text_rgb != 'rgba(0, 0, 0, 0.0)' %}
            --color-custom-text: {{ section.settings.color-body-text }};
        {% endif %}

        {% if section.settings.image_ratio == 'square' %}
            --aspect-ratio: 1/1;
        {% elsif section.settings.image_ratio == 'portrait' %}
            --aspect-ratio: var(--aspect-ratio-portait);
        {% endif %}
        --grid-col: {{ section.settings.columns_per_row }};
        --grid-col-mobile: {{ section.settings.columns_per_row_mobile | floor }};
        --gap-stack: {{ section.settings.spacing_desktop }}px;
        --gap-stack-mobile: {{ section.settings.spacing_mobile }}px;
    }

    [data-section-id="{{ section.id }}"] .headline__title
    {
        {% if text_rgb != 'rgba(0, 0, 0, 0.0)' %}
        --color-custom-text: {{ section.settings.color-body-text }};
        {% endif %}
    }
    {%- for block in section.blocks -%}
    {% assign background_rgb = block.settings.color-overlay  | color_to_rgb %}
    {% assign text_rgb = block.settings['color-body-text'] | color_to_rgb %}

      [data-block-id="{{ block.id }}"] {
        {% if background_rgb != 'rgba(0, 0, 0, 0.0)' %}
          --color-overlay-rgb: {{ block.settings.color-overlay | color_to_rgb | remove: 'rgb(' | remove: ')' }};
          --color-overlay-opacity: {{ block.settings.color-overlay-opacity | divided_by: 100.0 }};
          {% endif %}
          {% if text_rgb != 'rgba(0, 0, 0, 0.0)' %}
            --color-custom-text: {{ block.settings.color-body-text }};
          {% endif %}

          --font-headline-scale-desk: {{ block.settings.size_heading | divided_by: 100.0 }};

          --font-headline-scale: {{ block.settings.size_heading_mobile | divided_by: 100.0 }};

          {% if section.settings.image_ratio == 'adapt' and block.settings.desktop_image %}
            --aspect-ratio: {{ block.settings.desktop_image.aspect_ratio }};
          {% endif %}
          {% if section.settings.image_ratio == 'adapt' and block.settings.mobile_image %}
            --aspect-ratio-mobile: {{ block.settings.mobile_image.aspect_ratio }};
          {% endif %}
      }
    {%- endfor -%}

</style>
<wt-drawer-content>
    <div class="wt-grid-view-with-drawer wt-grid-box {% if settings.animations and section.settings['full-width-enabled'] != true %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}" data-section-id="{{ section.id }}">
        {% if section.settings.advanced_heading %}
        {% if section.settings.heading_richtext != blank %}
            <div class="headline headline--rich {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}">
                {{ section.settings.heading_richtext }}
            </div>
        {% endif %}
    {% else %}
        {% if section.settings.title != blank %}
            {% render 'headline', title: section.settings.title %}
        {% endif %}
    {% endif %}

    {% if section.settings.cards_layout == 'carousel' %}
        <script type="module" src="{{ 'slider2.js' | asset_url }}" defer="defer"></script>
        <slideshow-section class="wt-slider {% if section.settings.full-width-enabled %}wt-slider--full{% endif %}">
    {% endif %}
    <div class="wt-slider-inner {% if section.settings.full-width-enabled %}wt-slider-inner--full{% endif %}">
        <div
            data-swiper
            class="wt-grid-view-with-drawer__container wt-grid-box__container {% if section.settings.full-width-enabled %}wt-grid-view-with-drawer__container--full wt-grid-box__container--full {% endif %}"
        >
            {% assign i = 0 %}
            <ul
            data-swiper-container
            class="wt-grid-view-with-drawer__ul wt-grid-box__ul {% if section.settings.cards_layout == 'carousel' %}wt-grid-view-with-drawer__ul--swipe wt-grid-box__ul--swipe{% else %} wt-slider__wrapper--stack {% endif %}"
            >
            {%- for block in section.blocks -%}
                {% assign i = i | plus: 1 %}
                <li 
                    class="wt-grid-view-with-drawer__li wt-grid-box__li block-{{ block.id }}" 
                    data-swiper-slide
                >
                <div
                    data-block-id="{{ block.id }}"
                    {% if settings.animations %}
                    data-cascade
                    style="--animation-order: {{ forloop.index }};"
                    {% endif %}
                    class="wt-grid-view-with-drawer__item wt-grid-box__item {% if settings.animations %} scroll-trigger animate--slide-in {% endif %} {% if settings.disabled_animations_on_mobile %} disabled-on-mobile {% endif %}"
                >
                    {% render 'hero',
                    type: 'single',
                    desktop_text_horizontal_position: block.settings.desktop_text_horizontal_position,
                    desktop_text_vertical_position: 'top',
                    mobile_text_horizontal_position: block.settings.mobile_text_horizontal_position,
                    mobile_text_vertical_position: 'top',
                    desktop_image: block.settings.desktop_image,
                    mobile_image: block.settings.mobile_image,
                    video: block.settings.video_hosted,
                    mobile_video: block.settings.video_hosted_mobile,
                    heading: block.settings.heading,
                    heading_disable_on_mobile: block.settings.heading_disable_on_mobile,
                    text_disable_on_mobile: block.settings.text_disable_on_mobile,
                    text: block.settings.text,
                    placeholder: 'collection-apparel-1',
                    %}
                </div>
                <div class="wt-grid-view-with-drawer__button wt-grid-box__button">
                    <div class="hero__button--gap hero__button--{{ block.settings.button_alignment }}">
                    <button
                        tabindex="0"
                        aria-label="Open drawer"
                        data-drawer-id="{{ block.id }}"
                        class="hero__button hero__button--primary {% if block.settings.button_select != 'primary' %} hero__button--secondary{% endif %} wt-drawer-content__trigger"
                    >
                        {% if block.settings.icon_select == 'plus' %}
                            {% render 'icons', id: 'plus' %}
                        {% else %}
                            {% render 'icons', id: 'arrow-right' %}
                        {% endif %}
                    </button>
                    </div>
                </div>
                {% render 'drawer-content',
                    drawer_id: block.id,
                    drawer_title: block.settings.drawer_heading,
                    drawer_image: block.settings.drawer_image,
                    drawer_video: block.settings.video,
                    drawer_content: block.settings.drawer_content,
                    drawer_page_content: block.settings.drawer_page.content,
                    %}
                </li>
            {%- endfor -%}
            </ul>

            {% if section.settings.cards_layout == 'carousel' %}
            <div class="swiper-button-next wt-slider__nav-btn wt-slider__nav-next wt-slider__nav-next--featured">
                {% render 'icons', id: 'arrow-right' %}
            </div>
            <div class="swiper-button-prev wt-slider__nav-btn wt-slider__nav-prev wt-slider__nav-prev--featured">
                {% render 'icons', id: 'arrow-left' %}
            </div>
            <div class="swiper-pagination wt-slider__pagination"></div>

            <script data-swiper-configuration type="text/json">
                {
                "slidesPerView": "auto",
                "spaceBetween": 16,
                "freeMode": false,
                "speed": 150,
                "grabCursor": false,
                "paginationType": "bullets",
                "breakpoints": {
                    "320": {
                    "slidesPerView": {% if section.settings.full-width-enabled %}1{% else %}{{ section.settings.columns_per_row_mobile }}{% endif %},
                    "slidesPerGroup": {{ section.settings.columns_per_row_mobile | floor }},
                    "spaceBetween": {% if section.settings.full-width-enabled %}0{% else %}{{ section.settings.spacing_mobile  }}{% endif %}
                    },
                    "900": {
                    "slidesPerView": {{ section.settings.columns_per_row }},
                    "slidesPerGroup": {{ section.settings.columns_per_row | floor }},
                    "spaceBetween": {% if section.settings.full-width-enabled %}0{% else %}{{ section.settings.spacing_desktop }}{% endif %}
                    }
                },
                "navigation": {
                    "nextEl": ".wt-slider__nav-next--featured",
                    "prevEl": ".wt-slider__nav-prev--featured"
                }
                }
            </script>
            {% endif %}
        </div>
    </div>
        {% if section.settings.cards_layout == 'carousel' %}
        </slideshow-section>
    {% endif %}
    </div>
</wt-drawer-content>
{% schema %}
{
