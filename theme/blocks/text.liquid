{% if block.settings.text %}
  <style>
    [data-block-id="{{ block.id }}"] {
      {% if block.settings.text_alignment_mobile != 'inherit' %}
        --text-alignment: {{ block.settings.text_alignment_mobile }};
      {% endif %}
      {% if block.settings.text_alignment != 'inherit' %}
        --text-alignment-desktop: {{ block.settings.text_alignment }};
      {% endif %}

      {% if block.settings.max_width > 0 %}
        --block-max-width: {{ block.settings.max_width }}px;
      {% endif %}
      {% if block.settings.margin_top %}
        --block-gap-top: {{ block.settings.margin_top }}px;
      {% endif %}
      {% if block.settings.margin_bottom %}
        --block-gap-bottom: {{ block.settings.margin_bottom }}px;
      {% endif %}
    }
  </style>
  {% assign prefix = 'hero' %}
  <div
    data-block-id="{{ block.id }}"
    class="
      {% if prefix %}{{ prefix }}{% else %}block{% endif %}__text {% if block.settings.disable_on_mobile %}{% if prefix %}{{ prefix }}{% else %}block{% endif %}__text--mobile{% endif %} rte
      wt-text-block
    "
  >
    {{ block.settings.text }}
  </div>
{% endif %}

{% schema %}
{
  "name": "t:blocks.text.name",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.settings.settings.text.label",
      "default": "<p>Give customers details about the banner image(s) or content on the template.</p>"
    },
    {
      "type": "header",
      "content": "t:sections.global.desktop_version"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        { "value": "inherit", "label": "t:blocks.text.settings.text_alignment.inherit.label" },
        { "value": "start", "label": "t:blocks.text.settings.text_alignment.left.label" },
        { "value": "center", "label": "t:blocks.text.settings.text_alignment.center.label" },
        { "value": "end", "label": "t:blocks.text.settings.text_alignment.right.label" }
      ],
      "default": "inherit",
      "label": "t:blocks.text.settings.text_alignment.label"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 0,
      "max": 1000,
      "step": 10,
      "default": 0,
      "label": "t:blocks.text.settings.max_width.label",
      "unit": "px",
      "info": "t:blocks.text.settings.max_width.info"
    },
    {
      "type": "header",
      "content": "t:sections.global.mobile_version"
    },
    {
      "type": "select",
      "id": "text_alignment_mobile",
      "options": [
        { "value": "inherit", "label": "t:blocks.text.settings.text_alignment.inherit.label" },
        { "value": "start", "label": "t:blocks.text.settings.text_alignment.left.label" },
        { "value": "center", "label": "t:blocks.text.settings.text_alignment.center.label" },
        { "value": "end", "label": "t:blocks.text.settings.text_alignment.right.label" }
      ],
      "default": "inherit",
      "label": "t:blocks.text.settings.text_alignment.label"
    },
    {
      "type": "checkbox",
      "id": "disable_on_mobile",
      "label": "t:sections.global.disable_on_mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "t:blocks.text.settings.block_spacing.label"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-top.label"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px",
      "label": "t:sections.settings.settings.distance-bottom.label",
      "info": "t:sections.settings.settings.distance-bottom.info"
    }
  ],
  "presets": [
    {
      "name": "t:blocks.text.name",
      "settings": {
        "text": "<p>Give customers details about the banner image(s) or content on the template.</p>"
      }
    }
  ]
}
{% endschema %}
