{%- if block.settings.left_content_type == 'icon' or block.settings.right_content_type == 'icon' -%}
  <style>
    [data-block-id="{{ block.id }}"] {
      --icon-size-left: {{ block.settings.left_icon_height }}px;
      --icon-size-right: {{ block.settings.right_icon_height }}px;
    }
  </style>
{%- endif -%}
<div
  data-block-id="{{ block.id }}"
  class="compare-products__row"
  role="row"
  {{ block.shopify_attributes }}
>
  <div class="compare-products__cell compare-products__cell--left" role="cell">
    {%- if block.settings.left_content_type == 'icon' and block.settings.left_icon != blank -%}
      {%- assign left_icon_alt = block.settings.left_icon.alt | default: "" | escape -%}
      {{
        block.settings.left_icon
        | image_url: width: 80
        | image_tag: class: 'compare-products__icon', loading: 'lazy', alt: left_icon_alt
      }}
    {%- elsif block.settings.left_content_type == 'icon' and block.settings.selected_left_icon != blank -%}
      {% render 'icons',
        id: block.settings.selected_left_icon,
        url: block.settings.image.url,
        icon_class: 'compare-products__icon'
      %}
    {%- else -%}
      {%- if block.settings.left_text != blank -%}
        {{ block.settings.left_text }}
      {%- else -%}
        <span>{{ 'sections.compare_products.placeholders.left_text' | t }}</span>
      {%- endif -%}
    {%- endif -%}
  </div>

  <div class="compare-products__cell compare-products__cell--center" role="cell">
    {%- if block.settings.center_text != blank -%}
      {{ block.settings.center_text }}
    {%- endif -%}
  </div>

  <div class="compare-products__cell compare-products__cell--right" role="cell">
    {%- if block.settings.right_content_type == 'icon' and block.settings.right_icon != blank -%}
      {%- assign right_icon_alt = block.settings.right_icon.alt | default: "" | escape -%}
      {{
        block.settings.right_icon
        | image_url: width: 80
        | image_tag: class: 'compare-products__icon', loading: 'lazy', alt: right_icon_alt
      }}
    {%- elsif block.settings.right_content_type == 'icon' and block.settings.selected_right_icon != blank -%}
      {% render 'icons',
        id: block.settings.selected_right_icon,
        url: block.settings.image.url,
        icon_class: 'compare-products__icon'
      %}
    {%- else -%}
      {%- if block.settings.right_text != blank -%}
        {{ block.settings.right_text }}
      {%- else -%}
        <span>{{ 'sections.compare_products.placeholders.right_text' | t }}</span>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>
