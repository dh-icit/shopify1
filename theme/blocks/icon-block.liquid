{% comment %}
  Renders icon block content. When used inside icons-container, the parent wraps
  this in <li>; the inner div provides .wt-icon-block styling in all contexts
  (including when used as a direct child of blur-banner-bottom-content).
{% endcomment %}
<div class="wt-icon-block">
  {% if block.settings.link %}
    <a class="wt-keys__link" href="{{ block.settings.link }}">
  {% endif %}
  {%- if block.settings.desktop_image == blank -%}
    {% render 'icons', id: block.settings.select_icon, url: block.settings.image.url, icon_class: 'wt-keys__icon' %}
  {% else %}
    {% assign image_class = 'wt-keys__image' %}
    {{
      block.settings.desktop_image
      | image_url: width: 200
      | image_tag:
        loading: 'lazy',
        sizes: '(min-width: 1000px) 620px, 100vw',
        widths: '375, 750, 1000, 1440',
        class: image_class
    }}
  {% endif %}
  <div class="wt-keys__content">
    <div class="wt-keys__title">{{ block.settings.heading }}</div>
    <div class="wt-keys__text">{{ block.settings.text }}</div>
  </div>
  {% if block.settings.link %}
    </a>
  {% endif %}
</div>

