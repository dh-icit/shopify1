<!--Gem_Page_Main_Editor--><div class="clearfix"></div><div class="gryffeditor"><div class="element-wrap" data-label="Text Block" id="e-1558486971351" data-icon="gpicon-textblock" data-ver="1" data-id="1558486971351"><div class="elm text-edit gf_gs-text-paragraph-1"><!-- Created with Shogun. --><div class="shogun-root" data-region="main" data-shogun-id="5b5bdb58f3638d0051c77806"><link rel="stylesheet" type="text/css" href="https:///d2c77227-a79e-4404-bef2-d65167f7d87f-2.css"><div id="s-f9cc2cb9-7e20-4a8c-950b-85e77a5b64a9" class="shg-c  shg-align-center"><div class="shogun-image-container"><br></div></div><script type="text/javascript" src="https:///d2c77227-a79e-4404-bef2-d65167f7d87f.js" async=""></script></div></div></div><!--gfsplit--><div data-label="Row" id="r-1558486990841" class="gf_row gf_row-gap-0" data-icon="gpicon-row" data-id="1558486990841" data-vivaldi-spatnav-clickable="1" data-extraclass="" style="visibility: visible;" data-row-gap="0px"><div class="gf_col-md-12 gf_column" id="c-1505664619544" data-id="1505664619544" style="min-height: auto;"><div data-label="Heading" id="e-1558486990929" class="element-wrap" data-icon="gpicon-heading" data-id="1558486990929" data-vivaldi-spatnav-clickable="1" style=""><div class="elm text-edit gf-elm-center gf-elm-center-lg gf-elm-center-md gf-elm-center-sm gf-elm-center-xs" style="" data-exc=""><h3 class="gf_gs-text-heading-2"><font color="#1c1c25" style="font-weight: normal;">FREQUENTLY ASKED QUESTIONS</font></h3></div></div><div data-label="Separator" id="e-1558486990904" class="element-wrap" data-icon="gpicon-separator" data-id="1558486990904" data-vivaldi-spatnav-clickable="1"><div class="elm gf-elm-center" data-align="left" data-exc=""><hr class="gf_separator"></div></div><div data-label="Accordion" data-key="accordion" data-atomgroup="module" id="m-1723487916506" class="module-wrap" data-icon="gpicon-accordion" data-ver="2" data-id="1723487916506"><div data-accordion-group="" class="module " data-opendefault="1" data-opentab="1" data-single="1" data-bordercolor="#cecece" data-bordersize="1px"><div data-accordion="" style="padding-bottom: "><div data-control="" data-index="1" data-key="content" class="chevron iCon-right text- item-content"><div data-label="Text Block" id="e-1723487916506-1" class="element-wrap" data-icon="gpicon-textblock" data-id="1723487916506-1" data-ver="1"><div class="elm text-edit gf_gs-text-paragraph-1"><h1 class="gf_gs-text-heading-2" style="letter-spacing: normal; text-align: left; font-size: 16px !important; font-family: Anton !important; line-height: 1.5em !important; color: rgb(0, 0, 0) !important; margin-bottom: 12px !important; font-weight: bold !important;"><span style="font-weight: normal;">GENERAL QUESTIONS</span></h1></div></div><button type="button" class="wrapp-icon"><span class="acc-icon" style="background-color:#000000"></span></button><button type="button" class="wrapp-icon"><span class="acc-icon" style="background-color:#000000"></span></button></div><div data-content="" style="margin-top: ; background-color: #FFFFFF"><article data-index="1" data-key="content1" class="item-content"><div data-label="Heading" id="e-1558486990833" class="element-wrap" data-icon="gpicon-heading" data-id="1558486990833" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-xs gf-elm-left-lg gf-elm-left-md gf-elm-left-sm" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: normal;">How do I become a subscriber?</span><br></h1></div></div><div data-label="Text Block" id="e-1558486990866" class="element-wrap" data-icon="gpicon-textblock" data-id="1558486990866" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><p style="font-size: 14px; text-align: inherit!important;">Select the type of subscription you’d like and add to cart. For the Lift Box, choose your shirt size (apparel is both men and women sizing) and either a tee or tank. Once you fill in the billing information, we ask for your shipping info, and you’re all set up!&nbsp;&nbsp;<br></p></div></div><div data-label="Heading" id="e-1558486990870" class="element-wrap" data-icon="gpicon-heading" data-id="1558486990870" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-xs gf-elm-left-lg gf-elm-left-md gf-elm-left-sm" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: normal;">DO YOU OFFER A MILITARY, VETERAN, OR FIRST RESPONDER DISCOUNT?</span></h1></div></div><div data-label="Text Block" id="e-1558486990945" class="element-wrap" data-icon="gpicon-textblock" data-id="1558486990945" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc="">We sure do! You can find out more by clicking <a href="https://www.theliftbx.com/pages/military-and-first-responder-discount-by-govx-id" class="">here</a>.<div><br></div></div></div><div data-label="Heading" id="e-1723487204953" class="element-wrap" data-icon="gpicon-heading" data-id="1723487204953" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-xs gf-elm-left-lg gf-elm-left-md gf-elm-left-sm" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: normal;">What is your return policy?</span></h1></div></div><div data-label="Text Block" id="e-1723487204918" class="element-wrap" data-icon="gpicon-textblock" data-id="1723487204918" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc="">Due to the unique nature of our product, no returns, exchanges, or refunds can be offered. Refunds are on a case by case basis. There is a $5 fee applied to your account if the transaction has already gone through. These fees cover the cost of processing fees. If you receive a damaged box, please email us at info@theliftbx.com, and we’ll be happy to assist you.</div></div><div data-label="Heading" id="e-1558489440428" class="element-wrap" data-icon="gpicon-heading" data-id="1558489440428" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: normal;">Do you ship internationally?</span>&nbsp;<br></h1></div></div><div data-label="Text Block" id="e-1558489440381" class="element-wrap" data-icon="gpicon-textblock" data-id="1558489440381" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><p style="font-size: 14px; text-align: inherit!important;">Not yet, but it’s in the works! We can ship to overseas Military bases!&nbsp;</p></div></div></article></div></div><div data-accordion="" style="padding-bottom: "><div data-control="" data-index="2" data-key="content" class="chevron iCon-right text- item-content"><div data-label="Text Block" id="e-1723487916506-2" class="element-wrap" data-icon="gpicon-textblock" data-id="1723487916506-2" data-ver="1"><div class="elm text-edit gf_gs-text-paragraph-1 gf-elm-left"><h1 class="gf_gs-text-heading-2" style="letter-spacing: normal; text-align: inherit!important; font-size: 16px !important; font-family: Anton !important; line-height: 1.5em !important; color: rgb(0, 0, 0) !important; margin-bottom: 12px !important; font-weight: bold !important;"><span style="font-weight: normal;">the lift box</span></h1></div></div><button type="button" class="wrapp-icon"><span class="acc-icon" style="background-color:#000000"></span></button><button type="button" class="wrapp-icon"><span class="acc-icon" style="background-color:#000000"></span></button></div><div data-content="" style="margin-top: ; background-color: #FFFFFF"><article data-index="2" data-key="content1" class="item-content"><div data-label="Heading" id="e-1558486990869" class="element-wrap" data-icon="gpicon-heading" data-id="1558486990869" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-xs gf-elm-left-lg gf-elm-left-md gf-elm-left-sm" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: normal;">What kind of items are included in the lift box?</span><br></h1></div></div><div data-label="Text Block" id="e-1558486990926" class="element-wrap" data-icon="gpicon-textblock" data-id="1558486990926" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><p style="text-align: inherit!important;">Every month, we partner with exciting brands to get you a different variety of supplements, snacks, and workout gear or equipment, as well as a shirt or tank in our custom fit styles and great designs. We take pride in only sending the best, high quality products and test everything out ourselves first. You can get sneak peeks monthly over on our socials and check out the monthly brands we featured on <a href="https://www.headlinesoversidelines.com/" class="">Headlines Over Sidelines</a>.</p></div></div><div data-label="Heading" id="e-1723487646752" class="element-wrap" data-icon="gpicon-heading" data-id="1723487646752" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-xs gf-elm-left-lg gf-elm-left-md gf-elm-left-sm" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: 400;">WHAT’S THE DIFFERENCE BETWEEN THE WOMEN AND MEN’S LIFT BOX?</span></h1></div></div><div data-label="Text Block" id="e-1723487646756" class="element-wrap" data-icon="gpicon-textblock" data-id="1723487646756" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><p style="font-size: 14px; text-align: inherit!important;">The only difference is between the shirt styles! All other products are identical. The Women’s shirt is a more fitted cut, with a scoop neck design. We recommend sizing up from your traditional street size, due to the athletic cut. The Men’s style is closer to the typical Unisex, however it is still an athletic cut. If you have any issues with the fit or style of your shirt, please reach out to us!</p></div></div><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1723488209746" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1723488209746" data-resolution="3000x3000"><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-lg gf-elm-center-md gf-elm-center-sm gf-elm-center-xs" data-exc=""><img src="https://ucarecdn.com/138ea2a3-ab67-4dee-8fbb-12b6a8785152/-/format/auto/-/preview/3000x3000/-/quality/lighter/Untitleddesign_95_e62aee99-233e-47c5-a375-afbeeb39285b.png" alt="" class="gf_image" data-gemlang="en" width="800" height="960" data-width="50%" data-height="auto" title="" natural-width="800" natural-height="960"></div></div><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1723488809787" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1723488809787" data-resolution="3000x3000"><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-lg gf-elm-center-md gf-elm-center-sm gf-elm-center-xs" data-exc=""><img src="https://ucarecdn.com/138ea2a3-ab67-4dee-8fbb-12b6a8785152/-/format/auto/-/preview/3000x3000/-/quality/lighter/Untitleddesign_95_e62aee99-233e-47c5-a375-afbeeb39285b.png" alt="" class="gf_image" data-gemlang="en" width="800" height="960" data-width="auto" data-height="auto" title="" natural-width="800" natural-height="960"></div></div><div data-label="Heading" id="e-1558486990912" class="element-wrap" data-icon="gpicon-heading" data-id="1558486990912" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-xs gf-elm-left-lg gf-elm-left-md gf-elm-left-sm" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: normal;">How do I edit and update size information?</span><br></h1></div></div><div data-label="Text Block" id="e-1558486990924" class="element-wrap" data-icon="gpicon-textblock" data-id="1558486990924" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><p style="font-size: 14px; text-align: inherit!important;">You are able to update any upcoming orders sizing directly in your profile. For any current processing orders, please reach out to us at info@theliftbx.com to change sizing. If you receive a shirt that just isn’t fitting the way you hoped, reach out to us and we will get you a new size!&nbsp;</p></div></div><div data-label="Heading" id="e-1723488647347" class="element-wrap" data-icon="gpicon-heading" data-id="1723488647347" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-xs gf-elm-left-lg gf-elm-left-md gf-elm-left-sm" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: 400;">CAN I GET MY BOX VEGAN/GLUTEN FREE/SUGAR FREE?</span></h1></div></div><div data-label="Text Block" id="e-1723487646686" class="element-wrap" data-icon="gpicon-textblock" data-id="1723487646686" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><p style="font-size: 14px; text-align: inherit!important;">At this time, we are unable to accommodate any customization for dietary needs. We do&nbsp;<span style="text-align: inherit; letter-spacing: 0px;">feature brands who are gluten free or vegan often but our brand partnership changes monthly. You can get sneak peeks of what we are featuring every month on our social media pages.&nbsp;</span></p><p style="font-size: 14px; text-align: inherit!important;"><br></p></div></div><div data-label="Heading" id="e-1723487646695" class="element-wrap" data-icon="gpicon-heading" data-id="1723487646695" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-xs gf-elm-left-lg gf-elm-left-md gf-elm-left-sm" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: 400;">WHEN DOES MY BOX SHIP?</span></h1></div></div><div data-label="Text Block" id="e-1723488654076" class="element-wrap" data-icon="gpicon-textblock" data-id="1723488654076" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><p style="font-size: 14px; text-align: inherit!important;">We pack and ship out the boxes during the week of the 20th, every month. If you order prior to the 15th, you are guaranteed a spot during pack week. Any orders placed after the 15th are allocated to the following month unless we have yet to sell out of the current month. You will receive a shipping confirmation via email with tracking information.&nbsp;</p></div></div><div data-label="Heading" id="e-1723488722443" class="element-wrap" data-icon="gpicon-heading" data-id="1723488722443" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-xs gf-elm-left-lg gf-elm-left-md gf-elm-left-sm" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: 400;">WHEN DOES THE BOX RENEW?</span></h1></div></div><div data-label="Text Block" id="e-1723488729893" class="element-wrap" data-icon="gpicon-textblock" data-id="1723488729893" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><p style="font-size: 14px; text-align: inherit!important;">Every month on the 1st at midnight. Any changes or cancellations made to the account after this date will apply to any FOLLOWING orders, not the current one. Please reach out to us if you need assistance with a current month’s order.&nbsp;</p></div></div><div data-label="Heading" id="e-1723488754857" class="element-wrap" data-icon="gpicon-heading" data-id="1723488754857" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-xs gf-elm-left-lg gf-elm-left-md gf-elm-left-sm" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: 400;">HOW DO I CANCEL?</span></h1></div></div><div data-label="Text Block" id="e-1723488760265" class="element-wrap" data-icon="gpicon-textblock" data-id="1723488760265" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><p style="font-size: 14px; text-align: inherit!important;">Simply log into your account, click “Edit Subscriptions” and hit the “Cancel” button. You can cancel, or pause, any time without hassle. If you need assistance of any kind, please reach out to us via chat, email, or text at any time. We respond within 24 hours. Just a heads up, if you’ve already paid for this monthly, this will only cancel any future orders, not current ones.&nbsp;</p></div></div></article></div></div><div data-accordion="" style="padding-bottom: "><div data-control="" data-index="3" data-key="content" class="chevron iCon-right text- item-content"><div data-label="Text Block" id="e-1723487916506-3" class="element-wrap" data-icon="gpicon-textblock" data-id="1723487916506-3" data-ver="1"><div class="elm text-edit gf_gs-text-paragraph-1 gf-elm-left"><h1 class="gf_gs-text-heading-2" style="letter-spacing: normal; text-align: inherit!important; font-size: 16px !important; font-family: Anton !important; line-height: 1.5em !important; color: rgb(0, 0, 0) !important; margin-bottom: 12px !important; font-weight: bold !important;"><span style="font-weight: normal;">THE SNACK BOX</span></h1></div></div><button type="button" class="wrapp-icon"><span class="acc-icon" style="background-color:#000000"></span></button><button type="button" class="wrapp-icon"><span class="acc-icon" style="background-color:#000000"></span></button></div><div data-content="" style="margin-top: ; background-color: #FFFFFF"><article data-index="3" data-key="content1" class="item-content"><div data-label="Heading" id="e-1723487204864" class="element-wrap" data-icon="gpicon-heading" data-id="1723487204864" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-xs gf-elm-left-lg gf-elm-left-md gf-elm-left-sm" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: normal;">What kind of items are included in the SNACK box?</span><br></h1></div></div><div data-label="Text Block" id="e-1723487204935" class="element-wrap" data-icon="gpicon-textblock" data-id="1723487204935" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><p style="font-size: 14px; text-align: inherit!important;">Snack Box is ideal for people who just want great snacks and supplements. It contains TWICE as many snacks as the Lift Box and the items are totally different from what's found in the Lift Box, making it a great selection on it's own or in addition to the Lift Box subscription.</p></div></div><div data-label="Heading" id="e-1583676813821" class="element-wrap" data-icon="gpicon-heading" data-id="1583676813821" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-xs gf-elm-left-lg gf-elm-left-md gf-elm-left-sm" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: normal;">When Do Boxes Ship Each month?</span><br></h1></div></div><div data-label="Text Block" id="e-1583676813766" class="element-wrap" data-icon="gpicon-textblock" data-id="1583676813766" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><p style="text-align: inherit!important;">We pack and ship out the boxes during the week of the 20th, every month. If you order prior to the 15th, you are guaranteed a spot during pack week. Any orders placed after the 15th are allocated to the following month unless we have yet to sell out of the current month. You will receive a shipping confirmation via email with tracking information.&nbsp;</p></div></div><div data-label="Heading" id="e-1723487314099" class="element-wrap" data-icon="gpicon-heading" data-id="1723487314099" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-xs gf-elm-left-lg gf-elm-left-md gf-elm-left-sm" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: normal;">WHEN DOES THE BOX RENEW?</span><br></h1></div></div><div data-label="Text Block" id="e-1558490657845" class="element-wrap" data-icon="gpicon-textblock" data-id="1558490657845" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><p style="text-align: inherit!important;">Every month on the 1st at midnight. Any changes or cancellations made to the account after this date will apply to any FOLLOWING orders, not the current one. Please reach out to us if you need assistance with a current month’s order.&nbsp;</p></div></div><div data-label="Heading" id="e-1558489440314" class="element-wrap" data-icon="gpicon-heading" data-id="1558489440314" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-xs gf-elm-left-lg gf-elm-left-md gf-elm-left-sm" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: normal;">How do I cancel?</span><br></h1></div></div><div data-label="Text Block" id="e-1723487321262" class="element-wrap" data-icon="gpicon-textblock" data-id="1723487321262" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><p style="font-size: 14px; text-align: inherit!important;">Simply log into your account, click “Edit Subscriptions” and hit the “Cancel” button. You can cancel, or pause, any time without hassle. If you need assistance of any kind, please reach out to us via chat, email, or text at any time. We respond within 24 hours. Just a heads up, if you’ve already paid for this monthly, this will only cancel any future orders, not current ones.&nbsp;</p></div></div><div data-label="Heading" id="e-1723488528771" class="element-wrap" data-icon="gpicon-heading" data-id="1723488528771" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-xs gf-elm-left-lg gf-elm-left-md gf-elm-left-sm" data-exc=""><h1 class="gf_gs-text-heading-2"><span style="font-weight: 400;">CAN I GET MY BOX VEGAN/GLUTEN FREE/SUGAR FREE?</span></h1></div></div><div data-label="Text Block" id="e-1723488534425" class="element-wrap" data-icon="gpicon-textblock" data-id="1723488534425" data-vivaldi-spatnav-clickable="1"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><p style="font-size: 14px; text-align: inherit!important;">At this time, we are unable to accommodate any customization for dietary needs. We do&nbsp;<span style="text-align: inherit; letter-spacing: 0px;">feature brands who are gluten free or vegan often but our brand partnership changes monthly. You can get sneak peeks of what we are featuring every month on our social media pages.&nbsp;</span></p><p style="font-size: 14px; text-align: inherit!important;"><br></p></div></div></article></div></div></div></div></div></div><!--gfsplit--><script>window.__gemStoreData = {};window.__gemStoreData.gemKeyValid = {};window.__gemStoreData.gemKeyValid.bestWayAddToCart = 1;</script></div><div id="divContentBk"></div><!--End_Gem_Page_Main_Editor-->
