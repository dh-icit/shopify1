{%- comment -%}
  Renders the image stack for scrollytelling-video (images-only or mobile fallback).
  Accepts: blocks, image_sizes_desktop, is_fallback (boolean)
{%- endcomment -%}
{%- assign image_widths = '400,600,800,1000,1200,1600,2000,2400' | split: ',' -%}
{%- assign container_class = 'wt-scrollytelling__image-frames' -%}
{%- if is_fallback -%}
  {%- assign container_class = container_class | append: ' wt-scrollytelling__image-frames--fallback' -%}
{%- endif -%}
<div class="{{ container_class }}" aria-hidden="true">
  {%- for block in blocks -%}
    {%- assign frame_image = block.settings.image -%}
    <div class="wt-scrollytelling__frame" data-block-index="{{ forloop.index0 }}">
      {%- if frame_image != blank -%}
        {%- if is_fallback -%}
          <img
            class="wt-scrollytelling__frame-img"
            data-src="{{ frame_image | image_url: width: 1200 }}"
            data-srcset="{% for w in image_widths %}{{ frame_image | image_url: width: w }} {{ w }}w{% unless forloop.last %}, {% endunless %}{% endfor %}"
            data-sizes="(min-width: 900px) {{ image_sizes_desktop }}, 100vw"
            alt=""
            width="{{ frame_image.width }}"
            height="{{ frame_image.height }}"
          >
        {%- else -%}
          <img
            class="wt-scrollytelling__frame-img"
            src="{{ frame_image | image_url: width: 1200 }}"
            srcset="{% for w in image_widths %}{{ frame_image | image_url: width: w }} {{ w }}w{% unless forloop.last %}, {% endunless %}{% endfor %}"
            sizes="(min-width: 900px) {{ image_sizes_desktop }}, 100vw"
            alt=""
            loading="lazy"
            decoding="async"
            width="{{ frame_image.width }}"
            height="{{ frame_image.height }}"
          >
        {%- endif -%}
      {%- else -%}
        <div class="wt-scrollytelling__frame-placeholder">
          {%- assign placeholder_index = forloop.index | modulo: 3 | plus: 1 -%}
          {%- assign placeholder_image = 'product-' | append: placeholder_index -%}
          {{ placeholder_image | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>
  {%- endfor -%}
</div>
