<div
  class="wt-drawer-content__source"
  aria-hidden="true"
  inert
>
  <div class="wt-drawer-content__source__inner">
    <div class="wt-drawer-content__source__header">
      <h2 class="wt-drawer-content__source__title__text" id="wt-drawer-content-title-{{ drawer_id }}">{{ drawer_title }}</h2>
      <button
        class="wt-drawer-content__source__close"
        type="button"
        aria-label="{{ 'accessibility.close' | t }}"
        data-drawer-id="{{ drawer_id }}"
      >
        {% render 'icons', id: 'close', icon_class: 'wt-cart__drawer__close' %}
      </button>
    </div>

    <div class="wt-drawer-content__source__body rte" id="wt-drawer-content-body-{{ drawer_id }}">
      {% if drawer_video %}
        <div class="wt-drawer-content__drawer__body__video">
          {{ drawer_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '1200x' }}
        </div>
      {% elsif drawer_image %}
      <div class="wt-drawer-content__drawer__body__image">
          {%- assign mobile_sizes = mobile_sizes | default: '100vw' -%}
          {%- assign mobile_widths = mobile_widths | default: '375,414,430,480,640,750,828,1080,1200,1440,1920,3000,3840' -%}
          {%- assign desktop_widths = desktop_widths | default: '750,1080,1440,1920,2560,3000,3840' -%}
          {%- assign loading_attr = 'lazy' -%}
          {{ drawer_image
              | image_url: width: 3840
              | image_tag:
                  width: drawer_image.width,
                  height: drawer_image.height,
                  class: 'hero__img',
                  sizes: mobile_sizes,
                  widths: mobile_widths,
                  loading: loading_attr
              }}
      </div>
      {% endif %}
      {%- if has_variant_metafields -%}
        {%- assign variables = metafield_variables | downcase | newline_to_br | split: '<br />' -%}
        <div class="wt-drawer-content__source__variant-content" data-block-id-for-variant-metafield="{{ drawer_id }}">
          {%- render 'collapsible-data',
            variables: variables,
            content: drawer_content,
            product: product,
            variant: product.selected_or_first_available_variant
          -%}
        </div>
      {%- else -%}
        {{ drawer_content }}
      {%- endif -%}
      {{ drawer_page_content }}
    </div>
  </div>
</div>
